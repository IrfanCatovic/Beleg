{
  "expo": {
    "name": "Planiner",
    "slug": "beleg-mobile",
    "scheme": "planiner",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c10dd732-8c2e-4f81-b8dc-f81d74e5933e",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.jpg"
    },
    "icon": "./assets/icon.jpg",
    "splash": {
      "image": "./assets/icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "rs.planiner.app",
      "associatedDomains": ["applinks:www.planiner.com"],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Planiner koristi lokaciju samo tokom praćenja aktivnosti da prikaže rutu i udaljenost.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Planiner prati rutu avanture u pozadini dok je aktivnost u toku.",
        "UIBackgroundModes": ["location"],
        "NSMotionUsageDescription": "Planiner koristi brojač koraka da prikaže dnevni napredak i korake tokom aktivnosti.",
        "NSPhotoLibraryUsageDescription": "Planiner koristi pristup slikama da postavite profilnu i naslovnu fotografiju i fotografije akcija."
      }
    },
    "android": {
      "package": "rs.planiner.app",
      "versionCode": 8,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.planiner.com",
              "pathPrefix": "/akcije"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.jpg",
        "backgroundColor": "#1a6b52"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACTIVITY_RECOGNITION",
        "com.google.android.gms.permission.ACTIVITY_RECOGNITION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.health.READ_STEPS",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-updates",
      "expo-task-manager",
      "expo-background-fetch",
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Planiner koristi lokaciju samo tokom praćenja aktivnosti da prikaže rutu i udaljenost.",
          "locationAlwaysAndWhenInUsePermission": "Planiner prati rutu avanture u pozadini dok je aktivnost u toku.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Planiner koristi pristup slikama da postavite profilnu i naslovnu fotografiju i fotografije akcija."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.jpg",
          "color": "#1a6b52"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Planiner čuva stiker avanture u galeriju kada to odaberete.",
          "savePhotosPermission": "Planiner čuva stiker avanture u galeriju kada to odaberete."
        }
      ],
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c10dd732-8c2e-4f81-b8dc-f81d74e5933e"
      }
    },
    "owner": "catko"
  }
}
