{
  "expo": {
    "name": "Planiner",
    "slug": "beleg-mobile",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c10dd732-8c2e-4f81-b8dc-f81d74e5933e",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.jpg",
    "splash": {
      "image": "./assets/icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "rs.planiner.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Planiner koristi lokaciju samo tokom praćenja aktivnosti da prikaže rutu i udaljenost.",
        "NSMotionUsageDescription": "Planiner koristi brojač koraka da prikaže dnevni napredak i korake tokom aktivnosti.",
        "NSPhotoLibraryUsageDescription": "Planiner koristi pristup slikama da postavite profilnu i naslovnu fotografiju i fotografije akcija."
      }
    },
    "android": {
      "package": "rs.planiner.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.jpg",
        "backgroundColor": "#1a6b52"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACTIVITY_RECOGNITION",
        "com.google.android.gms.permission.ACTIVITY_RECOGNITION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-updates",
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Planiner koristi lokaciju samo tokom praćenja aktivnosti da prikaže rutu i udaljenost."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Planiner koristi pristup slikama da postavite profilnu i naslovnu fotografiju i fotografije akcija."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c10dd732-8c2e-4f81-b8dc-f81d74e5933e"
      }
    },
    "owner": "catko"
  }
}
